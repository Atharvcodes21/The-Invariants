# ─────────────────────────────────────────────
# VoiceRx Sync — .gitignore
# ─────────────────────────────────────────────

# ── Secrets — NEVER commit ───────────────────
.env
.env.local
.env.production
.env.*.local
backend/.env
**/*.env

# ── Python ───────────────────────────────────
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
*.pyw
*.pyz
*.egg-info/
dist/
build/
*.egg
.eggs/

# Virtual environments
venv/
.venv/
env/
ENV/
backend/venv/
backend/.venv/

# ── Node / Next.js ───────────────────────────
node_modules/
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.vercel/
*.tsbuildinfo
next-env.d.ts

# ── Temp files (audio, PDF, recordings) ──────
temp/
backend/temp/
*.wav
*.mp3
*.m4a
*.webm
*.ogg
*.pdf

# ── Streamlit legacy ─────────────────────────
.streamlit/secrets.toml
prescriptions.db

# ── OS ───────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini

# ── IDE / Editor ─────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Logs ─────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Coverage / Testing ───────────────────────
.coverage
htmlcov/
.pytest_cache/