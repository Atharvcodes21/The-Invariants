# ==============================================================================
# VoiceRx Sync — Environment Variables Reference
# ==============================================================================
# This project has TWO separate .env files:
#
#   backend/.env       →  FastAPI backend  (copy from backend/.env.example)
#   frontend/.env.local →  Next.js frontend (copy from frontend/.env.local.example)
#
# The old root-level .env (Streamlit era) is no longer used.
# ==============================================================================


# ── BACKEND  (backend/.env) ────────────────────────────────────────────────────

# Groq API — STT (Whisper) + LLM (LLaMA 3)
# Get yours free at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# MongoDB Atlas connection string
# URL-encode special chars in password:  # → %23   * → %2A   @ → %40
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/voicerx?appName=YourApp
MONGO_DB_NAME=voicerx

# Firebase Web API key — used by backend to verify Google sign-in tokens
# Firebase console → Project Settings → General → Web API Key
FIREBASE_API_KEY=your_firebase_web_api_key

# JWT — sign session tokens (use a long random string in production)
JWT_SECRET=change-this-to-a-long-random-string

# Patient ID encryption key (OPTIONAL)
# If blank, a key is auto-derived from JWT_SECRET (safe for single-server setups).
# For multi-server / higher security, generate a dedicated key:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# PATIENT_ENCRYPT_KEY=

# CORS — comma-separated list of allowed frontend origins
# Set to your Render frontend URL after deploying, e.g.:
#   ALLOWED_ORIGINS=https://voicerx-frontend.onrender.com,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000


# ── FRONTEND  (frontend/.env.local) ────────────────────────────────────────────

# URL of the FastAPI backend (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Firebase project config
# Firebase console → Project Settings → Your Apps → Web App → Config
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
