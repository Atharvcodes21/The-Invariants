# ──────────────────────────────────────────────────────────────────────
# VoiceRx Sync — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit the real .env to git.
# ──────────────────────────────────────────────────────────────────────

# ── Groq (Speech-to-Text + LLM) ──────────────────────────────────────
# Get your key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── MongoDB Atlas ─────────────────────────────────────────────────────
# Create a free cluster at: https://cloud.mongodb.com
# URL-encode special chars in password: # → %23, * → %2A
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?appName=<AppName>
MONGO_DB_NAME=voicerx

# ── Google OAuth 2.0 ─────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# OAuth client type: Desktop app  (PKCE is handled automatically)
# Add http://localhost:8501 as an Authorized Redirect URI
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8501

# Required: allows OAuth over HTTP on localhost (remove in production)
OAUTHLIB_INSECURE_TRANSPORT=1
