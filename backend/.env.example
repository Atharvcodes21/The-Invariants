# ─────────────────────────────────────────────────────────────────────────────
# VoiceRx Sync — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file.
# ─────────────────────────────────────────────────────────────────────────────

# Groq API — used for Whisper STT + LLaMA extraction
# Get yours at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?appName=<app>
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/voicerx?appName=YourApp
MONGO_DB_NAME=voicerx

# Firebase — for verifying Google sign-in tokens on the backend
# Get from Firebase console → Project Settings → General → Web API Key
FIREBASE_API_KEY=your_firebase_web_api_key_here

# JWT secret — used to sign session tokens (use a long random string in production)
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# Patient ID encryption key (OPTIONAL)
# If not set, a key is automatically derived from JWT_SECRET.
# To generate a dedicated key:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# PATIENT_ENCRYPT_KEY=your_generated_fernet_key_here
